<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Illustration Section -->
            <LinearLayout
                android:id="@+id/illustrationSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="32dp">

                <!-- Lock Icon Circle -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/iconCard"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    app:cardCornerRadius="60dp"
                    app:cardElevation="8dp"
                    app:cardBackgroundColor="@color/md_theme_secondaryContainer">

                    <ImageView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_lock_idle_lock"
                        app:tint="@color/md_theme_secondary"
                        android:contentDescription="@string/reset_password" />
                </androidx.cardview.widget.CardView>

                <!-- Title -->
                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/reset_password"
                    android:textAppearance="@style/TextAppearance.Cinescope.HeadlineMedium"
                    android:textColor="@color/md_theme_onBackground"
                    android:textStyle="bold" />

                <!-- Subtitle -->
                <TextView
                    android:id="@+id/tvSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginHorizontal="32dp"
                    android:text="@string/enter_new_password"
                    android:textAppearance="@style/TextAppearance.Cinescope.BodyMedium"
                    android:textColor="@color/md_theme_onSurfaceVariant"
                    android:gravity="center" />

                <!-- Email Display -->
                <TextView
                    android:id="@+id/tvEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textAppearance="@style/TextAppearance.Cinescope.BodySmall"
                    android:textColor="@color/md_theme_primary"
                    android:textStyle="bold"
                    tools:text="user@example.com" />
            </LinearLayout>

            <!-- Reset Form Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/formCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <!-- OTP/Reset Code Input -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/verification_code"
                        android:textAppearance="@style/TextAppearance.Cinescope.LabelLarge"
                        android:textColor="@color/md_theme_onSurface"
                        android:textStyle="bold" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilCode"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="20dp"
                        android:hint="@string/reset_code_hint"
                        app:startIconDrawable="@android:drawable/ic_menu_info_details"
                        app:boxStrokeColor="@color/md_theme_primary"
                        app:hintTextColor="@color/md_theme_primary"
                        app:startIconTint="@color/md_theme_onSurfaceVariant"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:errorEnabled="true"
                        app:helperText="@string/otp_helper_text"
                        app:helperTextTextColor="@color/md_theme_onSurfaceVariant">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etCode"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:maxLength="6"
                            android:textSize="18sp"
                            android:letterSpacing="0.2"
                            android:textColor="@color/md_theme_onSurface" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- New Password Section -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/new_password"
                        android:textAppearance="@style/TextAppearance.Cinescope.LabelLarge"
                        android:textColor="@color/md_theme_onSurface"
                        android:textStyle="bold" />

                    <!-- New Password Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilNewPassword"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="16dp"
                        android:hint="@string/new_password"
                        app:endIconMode="password_toggle"
                        app:startIconDrawable="@android:drawable/ic_lock_idle_lock"
                        app:boxStrokeColor="@color/md_theme_primary"
                        app:hintTextColor="@color/md_theme_primary"
                        app:startIconTint="@color/md_theme_onSurfaceVariant"
                        app:endIconTint="@color/md_theme_onSurfaceVariant"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:errorEnabled="true"
                        app:helperText="@string/password_requirements"
                        app:helperTextTextColor="@color/md_theme_onSurfaceVariant">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etNewPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:textColor="@color/md_theme_onSurface" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Confirm New Password Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilConfirmPassword"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:hint="@string/confirm_new_password"
                        app:endIconMode="password_toggle"
                        app:startIconDrawable="@android:drawable/ic_lock_idle_lock"
                        app:boxStrokeColor="@color/md_theme_primary"
                        app:hintTextColor="@color/md_theme_primary"
                        app:startIconTint="@color/md_theme_onSurfaceVariant"
                        app:endIconTint="@color/md_theme_onSurfaceVariant"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:errorEnabled="true">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etConfirmPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:textColor="@color/md_theme_onSurface" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Password Strength Indicator -->
                    <LinearLayout
                        android:id="@+id/passwordStrengthLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="24dp"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/password_strength"
                            android:textAppearance="@style/TextAppearance.Cinescope.BodySmall"
                            android:textColor="@color/md_theme_onSurfaceVariant" />

                        <TextView
                            android:id="@+id/tvPasswordStrength"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:textAppearance="@style/TextAppearance.Cinescope.BodySmall"
                            android:textStyle="bold"
                            tools:text="Strong"
                            tools:textColor="@color/md_theme_primary" />
                    </LinearLayout>

                    <!-- Reset Password Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnReset"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="@string/reset_password"
                        android:textSize="16sp"
                        app:cornerRadius="12dp"
                        style="@style/Widget.Material3.Button" />

                    <!-- Resend Code Link -->
                    <TextView
                        android:id="@+id/tvResendCode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="16dp"
                        android:text="@string/resend_code"
                        android:textAppearance="@style/TextAppearance.Cinescope.BodyMedium"
                        android:textColor="@color/md_theme_primary"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Back to Login -->
            <TextView
                android:id="@+id/tvBackToLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="24dp"
                android:text="@string/back_to_login"
                android:textAppearance="@style/TextAppearance.Cinescope.BodyMedium"
                android:textColor="@color/md_theme_onSurfaceVariant"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp" />

        </LinearLayout>
    </ScrollView>

    <!-- Loading Overlay -->
    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        tools:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@color/md_theme_surface"
            android:padding="32dp"
            android:elevation="8dp">

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:indeterminateTint="@color/md_theme_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/resetting_password"
                android:textAppearance="@style/TextAppearance.Cinescope.BodyMedium"
                android:textColor="@color/md_theme_onSurface" />
        </LinearLayout>
    </FrameLayout>

    <!-- Success State (Initially Hidden) -->
    <FrameLayout
        android:id="@+id/successOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/md_theme_background"
        android:visibility="gone"
        tools:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp">

            <!-- Success Icon -->
            <androidx.cardview.widget.CardView
                android:id="@+id/successIconCard"
                android:layout_width="120dp"
                android:layout_height="120dp"
                app:cardCornerRadius="60dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="@color/md_theme_primaryContainer">

                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/checkbox_on_background"
                    app:tint="@color/md_theme_primary"
                    android:contentDescription="@string/success" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/password_reset_success"
                android:textAppearance="@style/TextAppearance.Cinescope.HeadlineMedium"
                android:textColor="@color/md_theme_onBackground"
                android:textStyle="bold"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginHorizontal="32dp"
                android:text="@string/password_reset_success_message"
                android:textAppearance="@style/TextAppearance.Cinescope.BodyMedium"
                android:textColor="@color/md_theme_onSurfaceVariant"
                android:gravity="center" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGoToLogin"
                android:layout_width="wrap_content"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:text="@string/go_to_login"
                android:textSize="15sp"
                android:paddingHorizontal="32dp"
                app:cornerRadius="12dp"
                style="@style/Widget.Material3.Button" />
        </LinearLayout>
    </FrameLayout>

</FrameLayout>
