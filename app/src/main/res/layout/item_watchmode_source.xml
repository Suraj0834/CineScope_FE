<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="160dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="@dimen/spacing_md"
    app:cardCornerRadius="@dimen/corner_radius_md"
    app:cardElevation="@dimen/elevation_sm"
    app:cardBackgroundColor="@color/md_theme_surfaceVariant"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md">

        <!-- Platform Icon Placeholder -->
        <ImageView
            android:id="@+id/ivSourceIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center_horizontal"
            android:src="@android:drawable/ic_menu_view"
            app:tint="@color/md_theme_primary"
            android:contentDescription="Streaming platform" />

        <TextView
            android:id="@+id/tvSourceName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/md_theme_onSurface"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="Netflix" />

        <TextView
            android:id="@+id/tvSourceType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textSize="11sp"
            android:textColor="@color/md_theme_onSurfaceVariant"
            android:gravity="center"
            tools:text="Subscription" />

        <TextView
            android:id="@+id/tvSourcePrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/md_theme_primary"
            android:gravity="center"
            tools:text="$12.99" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/tvSourceFormat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="@color/md_theme_onSurfaceVariant"
                android:paddingEnd="4dp"
                tools:text="HD" />

            <View
                android:layout_width="3dp"
                android:layout_height="3dp"
                android:background="@drawable/dot_separator" />

            <TextView
                android:id="@+id/tvSourceRegion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="@color/md_theme_onSurfaceVariant"
                android:paddingStart="4dp"
                tools:text="US" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
