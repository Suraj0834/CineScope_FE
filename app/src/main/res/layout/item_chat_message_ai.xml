<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingBottom="@dimen/spacing_md"
    android:gravity="start|top">

    <com.google.android.material.imageview.ShapeableImageView
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginEnd="@dimen/spacing_sm"
        android:src="@drawable/ic_ai_avatar"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Cinescope.Circle"
        android:background="@color/md_theme_primaryContainer"
        android:padding="6dp"
        app:tint="@color/md_theme_onPrimaryContainer" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardCornerRadius="@dimen/corner_radius_lg"
        app:cardBackgroundColor="@color/md_theme_surface"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/md_theme_outlineVariant"
        android:layout_marginEnd="48dp">

        <TextView
            android:id="@+id/tvMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="@dimen/spacing_md"
            android:text="Hello! How can I help you discover movies today?"
            android:textAppearance="@style/TextAppearance.Cinescope.BodyMedium"
            android:textColor="@color/md_theme_onSurface"
            android:lineSpacingExtra="4dp" />

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
