<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="8dp"
    android:gravity="start|top">

    <!-- Enhanced AI Avatar with gradient background -->
    <androidx.cardview.widget.CardView
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="12dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="3dp"
        app:cardBackgroundColor="@color/md_theme_primaryContainer">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Gradient overlay for depth -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/md_theme_primary"
                android:alpha="0.1" />

            <!-- AI Icon -->
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_ai_avatar"
                app:tint="@color/md_theme_onPrimaryContainer"
                android:contentDescription="@string/ai_assistant" />
        </FrameLayout>
    </androidx.cardview.widget.CardView>

    <!-- Message Content Container -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginEnd="40dp">

        <!-- AI Label Badge -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ai_assistant"
                android:textAppearance="@style/TextAppearance.Cinescope.LabelSmall"
                android:textColor="@color/md_theme_primary"
                android:textStyle="bold"
                android:textSize="11sp" />

            <!-- Verified/Official Badge -->
            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginStart="4dp"
                android:src="@android:drawable/checkbox_on_background"
                app:tint="@color/md_theme_primary"
                android:contentDescription="@string/verified" />
        </LinearLayout>

        <!-- Message Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/md_theme_surfaceVariant"
            app:cardElevation="1dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Message Text -->
                <TextView
                    android:id="@+id/tvMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:textAppearance="@style/TextAppearance.Cinescope.BodyMedium"
                    android:textColor="@color/md_theme_onSurface"
                    android:lineSpacingExtra="4dp"
                    android:textSize="14sp"
                    tools:text="Hello! How can I help you discover movies today?" />

                <!-- Typing Indicator (hidden by default) -->
                <LinearLayout
                    android:id="@+id/typingIndicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center"
                    android:visibility="gone"
                    tools:visibility="gone">

                    <View
                        android:id="@+id/dot1"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginHorizontal="3dp"
                        android:background="@drawable/bg_step_active" />

                    <View
                        android:id="@+id/dot2"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginHorizontal="3dp"
                        android:background="@drawable/bg_step_active" />

                    <View
                        android:id="@+id/dot3"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginHorizontal="3dp"
                        android:background="@drawable/bg_step_active" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Metadata Row (Timestamp + Actions) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Timestamp -->
            <TextView
                android:id="@+id/tvTimestamp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textAppearance="@style/TextAppearance.Cinescope.BodySmall"
                android:textColor="@color/md_theme_onSurfaceVariant"
                android:textSize="11sp"
                android:alpha="0.7"
                tools:text="2:45 PM" />

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end">

                <!-- Copy Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCopy"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp"
                    app:icon="@android:drawable/ic_menu_save"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconSize="16dp"
                    app:iconTint="@color/md_theme_onSurfaceVariant"
                    app:cornerRadius="16dp"
                    android:contentDescription="@string/copy"
                    style="@style/Widget.Material3.Button.IconButton" />

                <!-- Share Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnShare"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginStart="4dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp"
                    app:icon="@android:drawable/ic_menu_share"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconSize="16dp"
                    app:iconTint="@color/md_theme_onSurfaceVariant"
                    app:cornerRadius="16dp"
                    android:contentDescription="@string/share"
                    style="@style/Widget.Material3.Button.IconButton" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
