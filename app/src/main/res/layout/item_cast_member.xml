<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="130dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="12dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@color/md_theme_surfaceVariant"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="12dp">

        <!-- Circular Profile Image with Border -->
        <androidx.cardview.widget.CardView
            android:layout_width="90dp"
            android:layout_height="90dp"
            app:cardCornerRadius="45dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/md_theme_surface">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivProfile"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_person_placeholder"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Cinescope.Circle"
                tools:src="@tools:sample/avatars" />

            <!-- Gradient Overlay for depth -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:drawable/dialog_holo_light_frame"
                android:alpha="0.05" />
        </androidx.cardview.widget.CardView>

        <!-- Actor Name -->
        <TextView
            android:id="@+id/tvName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textAppearance="@style/TextAppearance.Cinescope.BodyMedium"
            android:textColor="@color/md_theme_onSurface"
            android:textStyle="bold"
            android:textSize="13sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:gravity="center"
            tools:text="Leonardo DiCaprio" />

        <!-- Character Name with icon -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@android:drawable/ic_menu_myplaces"
                app:tint="@color/md_theme_primary"
                android:alpha="0.7"
                android:contentDescription="@string/character" />

            <TextView
                android:id="@+id/tvCharacter"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:textAppearance="@style/TextAppearance.Cinescope.BodySmall"
                android:textColor="@color/md_theme_onSurfaceVariant"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:gravity="center"
                tools:text="Cobb" />
        </LinearLayout>

        <!-- Optional: Popularity indicator (can be hidden if not needed) -->
        <LinearLayout
            android:id="@+id/layoutPopularity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:visibility="gone"
            tools:visibility="visible">

            <ImageView
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:src="@android:drawable/btn_star_big_on"
                app:tint="@color/rating_gold"
                android:contentDescription="@string/popularity" />

            <TextView
                android:id="@+id/tvPopularity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:textAppearance="@style/TextAppearance.Cinescope.BodySmall"
                android:textColor="@color/md_theme_onSurfaceVariant"
                android:textSize="10sp"
                android:textStyle="bold"
                tools:text="8.5" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
