<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="240dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="12dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="5dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@color/md_theme_surface"
    android:foreground="?attr/selectableItemBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Thumbnail Container with 16:9 ratio -->
        <FrameLayout
            android:id="@+id/thumbnailContainer"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintDimensionRatio="16:9"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Video Thumbnail -->
            <ImageView
                android:id="@+id/ivThumbnail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="@string/video_thumbnail"
                tools:background="@android:color/darker_gray" />

            <!-- Dark Gradient Overlay for better text visibility -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/gradient_overlay"
                android:alpha="0.4" />

            <!-- Enhanced Play Button -->
            <androidx.cardview.widget.CardView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center"
                app:cardCornerRadius="28dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/md_theme_error">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_media_play"
                    app:tint="@color/md_theme_onError"
                    android:contentDescription="@string/play_video" />
            </androidx.cardview.widget.CardView>

            <!-- Duration Badge (bottom-right) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/durationBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_margin="8dp"
                app:cardCornerRadius="6dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="#CC000000"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/tvDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="7dp"
                    android:paddingVertical="3dp"
                    android:textSize="11sp"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    tools:text="2:45" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Video Type Badge (top-left) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/typeBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_margin="8dp"
                app:cardCornerRadius="6dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/md_theme_primary">

                <TextView
                    android:id="@+id/tvType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:textSize="10sp"
                    android:textColor="@color/md_theme_onPrimary"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    tools:text="TRAILER" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Quality Badge (top-right, optional) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/qualityBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="8dp"
                app:cardCornerRadius="4dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="#CC000000"
                android:visibility="gone"
                tools:visibility="gone">

                <TextView
                    android:id="@+id/tvQuality"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:textSize="9sp"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    tools:text="HD" />
            </com.google.android.material.card.MaterialCardView>
        </FrameLayout>

        <!-- Video Info Container -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp"
            android:background="@color/md_theme_surface"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/thumbnailContainer">

            <!-- Video Title -->
            <TextView
                android:id="@+id/tvVideoTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Cinescope.BodyMedium"
                android:textColor="@color/md_theme_onSurface"
                android:textStyle="bold"
                android:textSize="13sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:lineSpacingExtra="2dp"
                tools:text="Official Trailer #2 - In Theaters Now" />

            <!-- Video Metadata (optional) -->
            <LinearLayout
                android:id="@+id/metadataLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone"
                tools:visibility="gone">

                <!-- Source Icon (YouTube) -->
                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@android:drawable/ic_menu_view"
                    app:tint="@color/md_theme_error"
                    android:contentDescription="@string/youtube" />

                <!-- View Count / Date -->
                <TextView
                    android:id="@+id/tvMetadata"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:textAppearance="@style/TextAppearance.Cinescope.BodySmall"
                    android:textColor="@color/md_theme_onSurfaceVariant"
                    android:textSize="11sp"
                    tools:text="1.2M views" />
            </LinearLayout>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
