<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background"
    android:fitsSystemWindows="true">

    <!-- Background Gradient Layer (Optional) -->
    <View
        android:id="@+id/backgroundGradient"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.05"
        android:background="@color/md_theme_primary" />

    <!-- Main Content Container -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="32dp">

        <!-- Top Section - Branding -->
        <LinearLayout
            android:id="@+id/brandingSection"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintBottom_toTopOf="@id/loadingSection"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="packed">

            <!-- App Logo/Icon -->
            <androidx.cardview.widget.CardView
                android:id="@+id/logoCard"
                android:layout_width="140dp"
                android:layout_height="140dp"
                app:cardBackgroundColor="@color/md_theme_primaryContainer"
                app:cardCornerRadius="70dp"
                app:cardElevation="12dp">

                <ImageView
                    android:id="@+id/ivAppLogo"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center"
                    android:src="@mipmap/ic_launcher"
                    android:contentDescription="@string/app_name" />
            </androidx.cardview.widget.CardView>

            <!-- App Name -->
            <TextView
                android:id="@+id/tvAppName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="@string/app_name"
                android:textAppearance="@style/TextAppearance.Cinescope.HeadlineLarge"
                android:textColor="@color/md_theme_primary"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <!-- App Tagline -->
            <TextView
                android:id="@+id/tvTagline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/discover_amazing_movies"
                android:textAppearance="@style/TextAppearance.Cinescope.BodyLarge"
                android:textColor="@color/md_theme_onSurfaceVariant"
                android:gravity="center" />
        </LinearLayout>

        <!-- Middle Section - Loading Indicator -->
        <LinearLayout
            android:id="@+id/loadingSection"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="64dp"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintBottom_toTopOf="@id/bottomSection"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/brandingSection">

            <!-- Circular Progress Indicator -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:indeterminateTint="@color/md_theme_primary" />

            <!-- Loading Text -->
            <TextView
                android:id="@+id/tvLoadingText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/loading"
                android:textAppearance="@style/TextAppearance.Cinescope.BodyMedium"
                android:textColor="@color/md_theme_onBackground"
                android:alpha="0.8" />

            <!-- Loading Progress Dots (Optional Animation) -->
            <LinearLayout
                android:id="@+id/progressDotsLayout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:visibility="gone"
                tools:visibility="visible">

                <View
                    android:id="@+id/dot1"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_marginHorizontal="4dp"
                    android:background="@drawable/bg_step_active" />

                <View
                    android:id="@+id/dot2"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_marginHorizontal="4dp"
                    android:background="@drawable/bg_step_inactive" />

                <View
                    android:id="@+id/dot3"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_marginHorizontal="4dp"
                    android:background="@drawable/bg_step_inactive" />
            </LinearLayout>
        </LinearLayout>

        <!-- Bottom Section - Version Info -->
        <LinearLayout
            android:id="@+id/bottomSection"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/loadingSection">

            <!-- Version Info -->
            <TextView
                android:id="@+id/tvVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/version_info"
                android:textAppearance="@style/TextAppearance.Cinescope.BodySmall"
                android:textColor="@color/md_theme_onSurfaceVariant"
                android:alpha="0.6"
                tools:text="Version 1.0.0" />

            <!-- Powered By (Optional) -->
            <TextView
                android:id="@+id/tvPoweredBy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/powered_by_ai"
                android:textAppearance="@style/TextAppearance.Cinescope.BodySmall"
                android:textColor="@color/md_theme_onSurfaceVariant"
                android:alpha="0.5"
                android:visibility="gone"
                tools:visibility="visible" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Error State (Initially Hidden) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/errorStateLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:padding="32dp"
        android:background="@color/md_theme_background"
        tools:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Error Icon -->
            <ImageView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@android:drawable/ic_dialog_alert"
                app:tint="@color/md_theme_error"
                android:alpha="0.6"
                android:contentDescription="@string/app_name" />

            <!-- Error Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/error_loading"
                android:textAppearance="@style/TextAppearance.Cinescope.TitleLarge"
                android:textColor="@color/md_theme_onBackground"
                android:textStyle="bold" />

            <!-- Error Message -->
            <TextView
                android:id="@+id/tvErrorMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/error_generic"
                android:textAppearance="@style/TextAppearance.Cinescope.BodyMedium"
                android:textColor="@color/md_theme_onSurfaceVariant"
                android:gravity="center"
                android:paddingHorizontal="16dp" />

            <!-- Retry Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRetry"
                android:layout_width="wrap_content"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:text="@string/retry"
                android:textSize="15sp"
                android:paddingHorizontal="32dp"
                app:icon="@android:drawable/ic_menu_rotate"
                app:iconGravity="start"
                app:cornerRadius="28dp"
                style="@style/Widget.Material3.Button.ElevatedButton" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>