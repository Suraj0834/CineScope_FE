<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingBottom="@dimen/spacing_md"
    android:gravity="end|top">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardCornerRadius="@dimen/corner_radius_lg"
        app:cardBackgroundColor="@color/md_theme_primary"
        app:cardElevation="0dp"
        android:layout_marginStart="48dp">

        <TextView
            android:id="@+id/tvMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="@dimen/spacing_md"
            android:text="Can you recommend a sci-fi movie?"
            android:textAppearance="@style/TextAppearance.Cinescope.BodyMedium"
            android:textColor="@color/md_theme_onPrimary"
            android:lineSpacingExtra="4dp" />

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
